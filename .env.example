# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Neon DB connection string
# Grab this from your Neon console (e.g., postgresql://user:password@ep-name.region.aws.neon.tech/dbname?sslmode=require)
DATABASE_URL=""

# AUTH_SECRET: Secret for NextAuth.js
# Generate one using: npx auth secret
AUTH_SECRET=""

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""