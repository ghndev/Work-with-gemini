# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="GEMINI_API_KEY"

# DATABASE_URL: Neon DB connection string
# Grab this from your Neon console (e.g., postgresql://user:password@ep-name.region.aws.neon.tech/dbname?sslmode=require)
DATABASE_URL=""

# AUTH_SECRET: Secret for NextAuth.js
# Generate one using: npx auth secret
AUTH_SECRET=""

# Google OAuth credentials for NextAuth.js
# Set these up in the Google Cloud Console and grab the Client ID and Secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Upstash Redis credentials for rate limiting and caching
# Grab these from your Upstash console
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""